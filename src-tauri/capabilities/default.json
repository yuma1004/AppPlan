{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:read-all",
    "fs:write-all",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "**" },
        { "path": "*/**" },
        { "path": "$HOME/**" }
      ]
    },
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:allow-execute",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "git",
          "cmd": "git",
          "args": true
        }
      ]
    }
  ]
}